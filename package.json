{
  "name": "reel.js",
  "version": "0.1.0",
  "description": "Modern TypeScript odometer-style number reels for dashboards, landing pages, and product UIs.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/your-name/reel.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-name/reel.js.git"
  },
  "bugs": {
    "url": "https://github.com/your-name/reel.js/issues"
  },
  "keywords": [
    "odometer",
    "counter",
    "animation",
    "number",
    "typescript",
    "esm"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup && cp src/index.css dist/index.css && node scripts/check-size.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.5.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.1.4",
    "jsdom": "^26.1.0",
    "terser": "^5.44.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
